{
  "version": 2,
  "functions": { "api/*.js": { "maxDuration": 30 } },
  "rewrites": [
    { "source": "/tutor", "destination": "/tutor/index.html" },
    { "source": "/tutor/", "destination": "/tutor/index.html" }
  ],
  "headers": [
    { "source": "/api/(.*)", "headers": [
      { "key": "Access-Control-Allow-Origin", "value": "*" },
      { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
    ]}
  ]
}
